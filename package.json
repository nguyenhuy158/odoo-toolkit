{
  "name": "odoo-dev-toolkit",
  "version": "0.3.0",
  "private": true,
  "description": "Chrome extension toolkit for Odoo developers.",
  "scripts": {
    "build": "tailwindcss -c tailwind.config.js -i src/input.css -o toolkit.css --minify",
    "watch": "tailwindcss -c tailwind.config.js -i src/input.css -o toolkit.css --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "test": "node --test"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0"
  }
}
